# JWT tajni ključ — OBAVEZNO za docker compose
# Generiraj s: openssl rand -base64 48
JWT_SECRET=

# MySQL lozinke — OBAVEZNO za docker compose
# Generiraj s: openssl rand -base64 24
DB_ROOT_PASSWORD=
DB_PASSWORD=

# IP adresa servera — za pristup s drugog računala na mreži
# Primjer: SERVER_IP=192.168.1.100
# Ostavi prazno za testiranje samo na istom računalu (localhost)
SERVER_IP=
