# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=XP

# Server
PORT=3000
UPLOADS_DIR=/app/uploads

# CORS — comma-separated lista dozvoljenih origina
CLIENT_URL=http://localhost:9000

# JWT
# OBAVEZNO: zamijeni s dugačkim random stringom prije pokretanja (npr. `openssl rand -base64 48`)
JWT_SECRET=zamijeni-ovo-dugackim-random-stringom
JWT_EXPIRES_IN=1d

# Opcionalno - rate limiti za auth rute (default: login 20, check-email 30 po 15 min).
# Povisiti samo za lokalni razvoj i e2e testove — u produkciji izostaviti.
# LOGIN_RATE_LIMIT_MAX=500
# CHECK_EMAIL_RATE_LIMIT_MAX=500

# Opcionalno - automatsko slanje invite emaila. Trenutno nije
# aktivirano po zahtjevu klijenta (admin ručno prosljeđuje link).
# Popuni ove varijable samo ako se odluka promijeni u budućnosti.
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your-email@veleri.hr
# SMTP_PASS=your-password
# SMTP_FROM="veleri.XP <your-email@veleri.hr>"
